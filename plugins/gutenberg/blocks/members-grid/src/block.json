{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wbcom-essential/members-grid",
	"version": "2.0.0",
	"title": "Members Grid",
	"category": "starter-buddypress",
	"icon": "screenoptions",
	"description": "Display BuddyPress members in a responsive grid layout.",
	"keywords": [ "members", "buddypress", "grid", "users", "community" ],
	"textdomain": "wbcom-essential",
	"example": {},
	"attributes": {
		"uniqueId": { "type": "string", "default": "" },
		"totalMembers": { "type": "number", "default": 12 },
		"columns": { "type": "number", "default": 4 },
		"columnsTablet": { "type": "number", "default": 2 },
		"columnsMobile": { "type": "number", "default": 1 },
		"sortType": { "type": "string", "default": "newest" },
		"showLastActive": { "type": "boolean", "default": true },
		"showFriendButton": { "type": "boolean", "default": true },
		"gap": { "type": "number", "default": 24 },
		"cardBg": { "type": "string", "default": "#ffffff" },
		"nameColor": { "type": "string", "default": "#1e1e2e" },
		"metaColor": { "type": "string", "default": "#6c757d" },
		"avatarSize": { "type": "number", "default": 80 },
		"cardBorderRadius": { "type": "number", "default": 12 },
		"padding": {
			"type": "object",
			"default": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
		},
		"paddingTablet": { "type": "object", "default": null },
		"paddingMobile": { "type": "object", "default": null },
		"paddingUnit": { "type": "string", "default": "px" },
		"margin": {
			"type": "object",
			"default": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
		},
		"marginTablet": { "type": "object", "default": null },
		"marginMobile": { "type": "object", "default": null },
		"marginUnit": { "type": "string", "default": "px" },
		"boxShadow": { "type": "boolean", "default": false },
		"shadowHorizontal": { "type": "number", "default": 0 },
		"shadowVertical": { "type": "number", "default": 4 },
		"shadowBlur": { "type": "number", "default": 8 },
		"shadowSpread": { "type": "number", "default": 0 },
		"shadowColor": { "type": "string", "default": "rgba(0, 0, 0, 0.12)" },
		"borderRadius": {
			"type": "object",
			"default": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
		},
		"borderRadiusUnit": { "type": "string", "default": "px" },
		"hideOnDesktop": { "type": "boolean", "default": false },
		"hideOnTablet": { "type": "boolean", "default": false },
		"hideOnMobile": { "type": "boolean", "default": false }
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"color": false,
		"spacing": false
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js"
}
