{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wbcom-essential/activity-feed",
	"version": "1.0.0",
	"title": "Activity Feed",
	"category": "starter-buddypress",
	"icon": "list-view",
	"description": "Display the BuddyPress activity stream with configurable filters, avatar display, and card styles.",
	"keywords": [ "activity", "feed", "stream", "buddypress", "community", "timeline" ],
	"textdomain": "wbcom-essential",
	"example": {},
	"attributes": {
		"uniqueId": { "type": "string", "default": "" },
		"totalActivities": { "type": "number", "default": 10 },
		"activityType": { "type": "string", "default": "" },
		"showAvatar": { "type": "boolean", "default": true },
		"showTime": { "type": "boolean", "default": true },
		"showAction": { "type": "boolean", "default": true },
		"showContent": { "type": "boolean", "default": true },
		"avatarSize": { "type": "number", "default": 50 },
		"cardBg": { "type": "string", "default": "#ffffff" },
		"nameColor": { "type": "string", "default": "#1e1e2e" },
		"contentColor": { "type": "string", "default": "#6c757d" },
		"timeColor": { "type": "string", "default": "#999999" },
		"borderColor": { "type": "string", "default": "#e9ecef" },
		"padding": {
			"type": "object",
			"default": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
		},
		"paddingTablet": { "type": "object", "default": null },
		"paddingMobile": { "type": "object", "default": null },
		"paddingUnit": { "type": "string", "default": "px" },
		"margin": {
			"type": "object",
			"default": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
		},
		"marginTablet": { "type": "object", "default": null },
		"marginMobile": { "type": "object", "default": null },
		"marginUnit": { "type": "string", "default": "px" },
		"boxShadow": { "type": "boolean", "default": false },
		"shadowHorizontal": { "type": "number", "default": 0 },
		"shadowVertical": { "type": "number", "default": 4 },
		"shadowBlur": { "type": "number", "default": 8 },
		"shadowSpread": { "type": "number", "default": 0 },
		"shadowColor": { "type": "string", "default": "rgba(0, 0, 0, 0.08)" },
		"borderRadius": {
			"type": "object",
			"default": { "top": 8, "right": 8, "bottom": 8, "left": 8 }
		},
		"borderRadiusUnit": { "type": "string", "default": "px" },
		"hideOnDesktop": { "type": "boolean", "default": false },
		"hideOnTablet": { "type": "boolean", "default": false },
		"hideOnMobile": { "type": "boolean", "default": false }
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"color": false,
		"spacing": false
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
