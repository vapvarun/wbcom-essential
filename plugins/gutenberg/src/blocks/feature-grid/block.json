{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wbcom-essential/feature-grid",
	"version": "1.0.0",
	"title": "Feature Grid",
	"category": "essential-marketing",
	"icon": "grid-view",
	"description": "Display feature cards in a responsive grid with icon/emoji, title, and description. Supports elevated, bordered, and flat card styles.",
	"keywords": [
		"features",
		"grid",
		"cards",
		"icons",
		"benefits",
		"services",
		"essential",
		"wbcom"
	],
	"textdomain": "wbcom-essential",
	"example": {
		"attributes": {
			"columns": 3,
			"cardStyle": "elevated"
		}
	},
	"attributes": {
		"uniqueId": {
			"type": "string",
			"default": ""
		},
		"columns": {
			"type": "number",
			"default": 3
		},
		"cardStyle": {
			"type": "string",
			"default": "elevated"
		},
		"features": {
			"type": "array",
			"default": [
				{
					"icon": "⚡",
					"title": "Lightning Fast",
					"description": "Optimized for speed and performance."
				},
				{
					"icon": "🔒",
					"title": "Secure",
					"description": "Built with security best practices."
				},
				{
					"icon": "🎨",
					"title": "Customizable",
					"description": "Fully customizable to match your brand."
				},
				{
					"icon": "📱",
					"title": "Responsive",
					"description": "Looks great on all devices."
				},
				{
					"icon": "🔧",
					"title": "Easy Setup",
					"description": "Get started in minutes, not hours."
				},
				{
					"icon": "💬",
					"title": "Support",
					"description": "World-class support when you need it."
				}
			]
		},
		"cardBg": {
			"type": "string",
			"default": "#ffffff"
		},
		"titleColor": {
			"type": "string",
			"default": "#1e1e2e"
		},
		"descriptionColor": {
			"type": "string",
			"default": "#6c757d"
		},
		"iconSize": {
			"type": "number",
			"default": 48
		},
		"padding": {
			"type": "object",
			"default": {
				"top": 48,
				"right": 24,
				"bottom": 48,
				"left": 24
			}
		},
		"paddingTablet": {
			"type": "object",
			"default": null
		},
		"paddingMobile": {
			"type": "object",
			"default": null
		},
		"paddingUnit": {
			"type": "string",
			"default": "px"
		},
		"margin": {
			"type": "object",
			"default": {
				"top": 0,
				"right": 0,
				"bottom": 0,
				"left": 0
			}
		},
		"marginTablet": {
			"type": "object",
			"default": null
		},
		"marginMobile": {
			"type": "object",
			"default": null
		},
		"marginUnit": {
			"type": "string",
			"default": "px"
		},
		"boxShadow": {
			"type": "boolean",
			"default": false
		},
		"shadowHorizontal": {
			"type": "number",
			"default": 0
		},
		"shadowVertical": {
			"type": "number",
			"default": 4
		},
		"shadowBlur": {
			"type": "number",
			"default": 8
		},
		"shadowSpread": {
			"type": "number",
			"default": 0
		},
		"shadowColor": {
			"type": "string",
			"default": "rgba(0, 0, 0, 0.12)"
		},
		"borderRadius": {
			"type": "object",
			"default": {
				"top": 0,
				"right": 0,
				"bottom": 0,
				"left": 0
			}
		},
		"borderRadiusUnit": {
			"type": "string",
			"default": "px"
		},
		"hideOnDesktop": {
			"type": "boolean",
			"default": false
		},
		"hideOnTablet": {
			"type": "boolean",
			"default": false
		},
		"hideOnMobile": {
			"type": "boolean",
			"default": false
		}
	},
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		],
		"color": false,
		"spacing": false
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
