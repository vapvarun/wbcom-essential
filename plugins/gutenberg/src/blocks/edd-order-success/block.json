{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wbcom-essential/edd-order-success",
	"version": "2.0.0",
	"title": "EDD Order Success",
	"category": "essential-woocommerce",
	"icon": "yes-alt",
	"description": "Display a purchase confirmation page with a success header, order receipt, and next steps for customers.",
	"keywords": [ "edd", "order", "success", "purchase", "receipt", "download", "confirmation" ],
	"textdomain": "wbcom-essential",
	"example": {
		"attributes": {
			"showSuccessHeader": true,
			"successMessage": "Thank you for your purchase!",
			"showNextSteps": true
		}
	},
	"attributes": {
		"showSuccessHeader": {
			"type": "boolean",
			"default": true
		},
		"successMessage": {
			"type": "string",
			"default": "Thank you for your purchase!"
		},
		"showNextSteps": {
			"type": "boolean",
			"default": true
		},
		"accountPageUrl": {
			"type": "string",
			"default": ""
		},
		"uniqueId": { "type": "string", "default": "" },
		"padding": {
			"type": "object",
			"default": { "top": 24, "right": 24, "bottom": 24, "left": 24 }
		},
		"paddingTablet": { "type": "object", "default": null },
		"paddingMobile": { "type": "object", "default": null },
		"paddingUnit": { "type": "string", "default": "px" },
		"margin": {
			"type": "object",
			"default": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
		},
		"marginTablet": { "type": "object", "default": null },
		"marginMobile": { "type": "object", "default": null },
		"marginUnit": { "type": "string", "default": "px" },
		"boxShadow": { "type": "boolean", "default": false },
		"shadowHorizontal": { "type": "number", "default": 0 },
		"shadowVertical": { "type": "number", "default": 4 },
		"shadowBlur": { "type": "number", "default": 8 },
		"shadowSpread": { "type": "number", "default": 0 },
		"shadowColor": { "type": "string", "default": "rgba(0, 0, 0, 0.12)" },
		"borderRadius": {
			"type": "object",
			"default": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
		},
		"borderRadiusUnit": { "type": "string", "default": "px" },
		"hideOnDesktop": { "type": "boolean", "default": false },
		"hideOnTablet": { "type": "boolean", "default": false },
		"hideOnMobile": { "type": "boolean", "default": false }
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
