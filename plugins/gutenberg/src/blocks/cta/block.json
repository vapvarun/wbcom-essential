{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wbcom-essential/cta",
	"version": "1.0.0",
	"title": "Call to Action",
	"category": "wbcom-essential",
	"icon": "megaphone",
	"description": "Conversion-focused section with heading, description, and a prominent CTA button.",
	"keywords": [ "cta", "call to action", "conversion", "button" ],
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"spacing": {
			"padding": true,
			"margin": true
		}
	},
	"attributes": {
		"heading": {
			"type": "string",
			"default": ""
		},
		"description": {
			"type": "string",
			"default": ""
		},
		"buttonText": {
			"type": "string",
			"default": "Get Started Now"
		},
		"buttonUrl": {
			"type": "string",
			"default": ""
		},
		"backgroundColor": {
			"type": "string",
			"default": "#f8fafc"
		},
		"textColor": {
			"type": "string",
			"default": "#1e1e1e"
		},
		"buttonColor": {
			"type": "string",
			"default": "#6366f1"
		},
		"buttonTextColor": {
			"type": "string",
			"default": "#ffffff"
		},
		"backgroundImage": {
			"type": "string",
			"default": ""
		},
		"backgroundImageId": {
			"type": "number",
			"default": 0
		},
		"textAlign": {
			"type": "string",
			"default": "center"
		},
		"layout": {
			"type": "string",
			"default": "stacked",
			"enum": [ "stacked", "inline" ]
		}
	},
	"textdomain": "wbcom-essential",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
