{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wbcom-essential/tabs",
	"version": "1.0.0",
	"title": "Tabs",
	"category": "essential-content",
	"icon": "table-row-before",
	"description": "Click-to-switch tabbed content panels with underline or boxed styles. Fully ARIA-compliant.",
	"keywords": ["tabs", "tabbed", "panel", "content", "switch", "navigation"],
	"textdomain": "wbcom-essential",
	"example": {
		"attributes": {
			"tabs": [
				{ "title": "Features", "content": "Discover our powerful features." },
				{ "title": "Benefits", "content": "Experience the benefits." },
				{ "title": "Pricing", "content": "Flexible pricing plans." }
			],
			"tabStyle": "underline"
		}
	},
	"attributes": {
		"uniqueId": { "type": "string", "default": "" },
		"tabs": {
			"type": "array",
			"default": [
				{ "title": "Features", "content": "Discover our powerful features designed to help you succeed." },
				{ "title": "Benefits", "content": "Experience the benefits of choosing our solution." },
				{ "title": "Pricing", "content": "Flexible pricing plans for businesses of all sizes." }
			]
		},
		"activeTab": { "type": "number", "default": 0 },
		"tabStyle": { "type": "string", "default": "underline" },
		"tabAlign": { "type": "string", "default": "left" },
		"activeColor": { "type": "string", "default": "#667eea" },
		"inactiveColor": { "type": "string", "default": "#6c757d" },
		"contentBg": { "type": "string", "default": "#ffffff" },
		"borderColor": { "type": "string", "default": "#e9ecef" },
		"padding": {
			"type": "object",
			"default": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
		},
		"paddingTablet": { "type": "object", "default": null },
		"paddingMobile": { "type": "object", "default": null },
		"paddingUnit": { "type": "string", "default": "px" },
		"margin": {
			"type": "object",
			"default": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
		},
		"marginTablet": { "type": "object", "default": null },
		"marginMobile": { "type": "object", "default": null },
		"marginUnit": { "type": "string", "default": "px" },
		"boxShadow": { "type": "boolean", "default": false },
		"shadowHorizontal": { "type": "number", "default": 0 },
		"shadowVertical": { "type": "number", "default": 4 },
		"shadowBlur": { "type": "number", "default": 8 },
		"shadowSpread": { "type": "number", "default": 0 },
		"shadowColor": { "type": "string", "default": "rgba(0, 0, 0, 0.12)" },
		"borderRadius": {
			"type": "object",
			"default": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
		},
		"borderRadiusUnit": { "type": "string", "default": "px" },
		"hideOnDesktop": { "type": "boolean", "default": false },
		"hideOnTablet": { "type": "boolean", "default": false },
		"hideOnMobile": { "type": "boolean", "default": false }
	},
	"supports": {
		"html": false,
		"align": ["wide", "full"],
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js"
}
