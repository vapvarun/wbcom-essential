{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wbcom-essential/profile-completion",
	"version": "1.0.0",
	"title": "Profile Completion",
	"category": "starter-buddypress",
	"icon": "chart-bar",
	"description": "Display a BuddyPress profile completion progress indicator with field group checklist for the currently logged-in user.",
	"keywords": [ "profile", "completion", "progress", "buddypress", "xprofile", "fields" ],
	"textdomain": "wbcom-essential",
	"example": {},
	"attributes": {
		"uniqueId": { "type": "string", "default": "" },
		"selectedGroups": { "type": "array", "default": [] },
		"checkProfilePhoto": { "type": "boolean", "default": true },
		"checkCoverPhoto": { "type": "boolean", "default": true },
		"skin": { "type": "string", "default": "circle" },
		"progressColor": { "type": "string", "default": "#667eea" },
		"trackColor": { "type": "string", "default": "#e9ecef" },
		"textColor": { "type": "string", "default": "#1e1e2e" },
		"completedColor": { "type": "string", "default": "#28a745" },
		"incompleteColor": { "type": "string", "default": "#6c757d" },
		"showGroupList": { "type": "boolean", "default": true },
		"showPercentage": { "type": "boolean", "default": true },
		"padding": {
			"type": "object",
			"default": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
		},
		"paddingTablet": { "type": "object", "default": null },
		"paddingMobile": { "type": "object", "default": null },
		"paddingUnit": { "type": "string", "default": "px" },
		"margin": {
			"type": "object",
			"default": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
		},
		"marginTablet": { "type": "object", "default": null },
		"marginMobile": { "type": "object", "default": null },
		"marginUnit": { "type": "string", "default": "px" },
		"boxShadow": { "type": "boolean", "default": false },
		"shadowHorizontal": { "type": "number", "default": 0 },
		"shadowVertical": { "type": "number", "default": 4 },
		"shadowBlur": { "type": "number", "default": 16 },
		"shadowSpread": { "type": "number", "default": 0 },
		"shadowColor": { "type": "string", "default": "rgba(0, 0, 0, 0.08)" },
		"borderRadius": {
			"type": "object",
			"default": { "top": 12, "right": 12, "bottom": 12, "left": 12 }
		},
		"borderRadiusUnit": { "type": "string", "default": "px" },
		"hideOnDesktop": { "type": "boolean", "default": false },
		"hideOnTablet": { "type": "boolean", "default": false },
		"hideOnMobile": { "type": "boolean", "default": false }
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"color": false,
		"spacing": false
	},
	"render": "file:./render.php",
	"viewScript": "file:./view.js",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
