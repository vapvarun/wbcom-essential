{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wbcom-essential/product-grid",
	"version": "1.0.0",
	"title": "Product Grid",
	"category": "essential-woocommerce",
	"icon": "grid-view",
	"description": "Display WooCommerce products in a responsive CSS Grid with category filter, sale badge, star rating, and add-to-cart button.",
	"keywords": [
		"woocommerce",
		"products",
		"grid",
		"shop",
		"ecommerce",
		"catalog",
		"essential",
		"wbcom"
	],
	"textdomain": "wbcom-essential",
	"example": {
		"attributes": {
			"columns": 4,
			"postsPerPage": 8
		}
	},
	"attributes": {
		"uniqueId": {
			"type": "string",
			"default": ""
		},
		"columns": {
			"type": "number",
			"default": 4
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"postsPerPage": {
			"type": "number",
			"default": 8
		},
		"categories": {
			"type": "array",
			"default": []
		},
		"orderBy": {
			"type": "string",
			"default": "date"
		},
		"order": {
			"type": "string",
			"default": "DESC"
		},
		"showImage": {
			"type": "boolean",
			"default": true
		},
		"showPrice": {
			"type": "boolean",
			"default": true
		},
		"showRating": {
			"type": "boolean",
			"default": true
		},
		"showAddToCart": {
			"type": "boolean",
			"default": true
		},
		"showSaleBadge": {
			"type": "boolean",
			"default": true
		},
		"imageRatio": {
			"type": "string",
			"default": "1/1"
		},
		"gap": {
			"type": "number",
			"default": 24
		},
		"cardBg": {
			"type": "string",
			"default": "#ffffff"
		},
		"titleColor": {
			"type": "string",
			"default": "#1e1e2e"
		},
		"priceColor": {
			"type": "string",
			"default": "#667eea"
		},
		"saleBadgeColor": {
			"type": "string",
			"default": "#e74c3c"
		},
		"padding": {
			"type": "object",
			"default": {
				"top": 0,
				"right": 0,
				"bottom": 0,
				"left": 0
			}
		},
		"paddingTablet": {
			"type": "object",
			"default": null
		},
		"paddingMobile": {
			"type": "object",
			"default": null
		},
		"paddingUnit": {
			"type": "string",
			"default": "px"
		},
		"margin": {
			"type": "object",
			"default": {
				"top": 0,
				"right": 0,
				"bottom": 0,
				"left": 0
			}
		},
		"marginTablet": {
			"type": "object",
			"default": null
		},
		"marginMobile": {
			"type": "object",
			"default": null
		},
		"marginUnit": {
			"type": "string",
			"default": "px"
		},
		"boxShadow": {
			"type": "boolean",
			"default": false
		},
		"shadowHorizontal": {
			"type": "number",
			"default": 0
		},
		"shadowVertical": {
			"type": "number",
			"default": 8
		},
		"shadowBlur": {
			"type": "number",
			"default": 24
		},
		"shadowSpread": {
			"type": "number",
			"default": 0
		},
		"shadowColor": {
			"type": "string",
			"default": "rgba(0, 0, 0, 0.08)"
		},
		"borderRadius": {
			"type": "object",
			"default": {
				"top": 8,
				"right": 8,
				"bottom": 8,
				"left": 8
			}
		},
		"borderRadiusUnit": {
			"type": "string",
			"default": "px"
		},
		"hideOnDesktop": {
			"type": "boolean",
			"default": false
		},
		"hideOnTablet": {
			"type": "boolean",
			"default": false
		},
		"hideOnMobile": {
			"type": "boolean",
			"default": false
		}
	},
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		],
		"color": {
			"background": true,
			"text": false
		},
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
