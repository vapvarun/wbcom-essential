{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wbcom-essential/timeline",
	"version": "1.0.0",
	"title": "Timeline",
	"category": "starter-content",
	"icon": "list-view",
	"description": "Vertical timeline with alternating sides, icon dots, and date labels.",
	"keywords": ["timeline", "history", "milestones", "events", "dates", "steps"],
	"textdomain": "wbcom-essential",
	"example": {
		"attributes": {
			"layout": "alternating",
			"items": [
				{ "date": "2024", "title": "Founded", "description": "Our company was founded.", "icon": "🚀" },
				{ "date": "2025", "title": "Growth", "description": "Expanded to thousands.", "icon": "📈" }
			]
		}
	},
	"attributes": {
		"uniqueId": { "type": "string", "default": "" },
		"items": {
			"type": "array",
			"default": [
				{ "date": "2024", "title": "Founded", "description": "Our company was founded with a vision.", "icon": "🚀" },
				{ "date": "2025", "title": "Growth", "description": "Expanded to serve thousands of customers.", "icon": "📈" },
				{ "date": "2026", "title": "Innovation", "description": "Launched groundbreaking new features.", "icon": "💡" }
			]
		},
		"layout": { "type": "string", "default": "alternating" },
		"lineColor": { "type": "string", "default": "#e9ecef" },
		"dotColor": { "type": "string", "default": "#667eea" },
		"dotSize": { "type": "number", "default": 40 },
		"cardBg": { "type": "string", "default": "#ffffff" },
		"dateColor": { "type": "string", "default": "#667eea" },
		"titleColor": { "type": "string", "default": "#1e1e2e" },
		"descriptionColor": { "type": "string", "default": "#6c757d" },
		"padding": {
			"type": "object",
			"default": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
		},
		"paddingTablet": { "type": "object", "default": null },
		"paddingMobile": { "type": "object", "default": null },
		"paddingUnit": { "type": "string", "default": "px" },
		"margin": {
			"type": "object",
			"default": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
		},
		"marginTablet": { "type": "object", "default": null },
		"marginMobile": { "type": "object", "default": null },
		"marginUnit": { "type": "string", "default": "px" },
		"boxShadow": { "type": "boolean", "default": false },
		"shadowHorizontal": { "type": "number", "default": 0 },
		"shadowVertical": { "type": "number", "default": 4 },
		"shadowBlur": { "type": "number", "default": 12 },
		"shadowSpread": { "type": "number", "default": 0 },
		"shadowColor": { "type": "string", "default": "rgba(0, 0, 0, 0.08)" },
		"borderRadius": {
			"type": "object",
			"default": { "top": 8, "right": 8, "bottom": 8, "left": 8 }
		},
		"borderRadiusUnit": { "type": "string", "default": "px" },
		"hideOnDesktop": { "type": "boolean", "default": false },
		"hideOnTablet": { "type": "boolean", "default": false },
		"hideOnMobile": { "type": "boolean", "default": false }
	},
	"supports": {
		"html": false,
		"align": ["wide", "full"],
		"color": {
			"background": true,
			"text": false
		},
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
