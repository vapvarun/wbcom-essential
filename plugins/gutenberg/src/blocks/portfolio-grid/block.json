{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wbcom-essential/portfolio-grid",
	"version": "1.0.0",
	"title": "Portfolio Grid",
	"category": "starter-content",
	"icon": "grid-view",
	"description": "Filterable portfolio or project grid with category tabs, hover effects, and responsive columns.",
	"keywords": ["portfolio", "grid", "projects", "filter", "gallery", "work"],
	"textdomain": "wbcom-essential",
	"example": {
		"attributes": {
			"columns": 3,
			"postsPerPage": 6,
			"hoverEffect": "overlay"
		}
	},
	"attributes": {
		"uniqueId":          { "type": "string",  "default": "" },
		"columns":           { "type": "number",  "default": 3 },
		"columnsTablet":     { "type": "number",  "default": 2 },
		"columnsMobile":     { "type": "number",  "default": 1 },
		"postsPerPage":      { "type": "number",  "default": 9 },
		"postType":          { "type": "string",  "default": "post" },
		"categories":        { "type": "array",   "default": [] },
		"showFilter":        { "type": "boolean", "default": true },
		"showExcerpt":       { "type": "boolean", "default": false },
		"showCategory":      { "type": "boolean", "default": true },
		"imageRatio":        { "type": "string",  "default": "1/1" },
		"gap":               { "type": "number",  "default": 16 },
		"hoverEffect":       { "type": "string",  "default": "overlay" },
		"overlayColor":      { "type": "string",  "default": "rgba(102, 126, 234, 0.85)" },
		"titleColor":        { "type": "string",  "default": "#ffffff" },
		"filterActiveColor": { "type": "string",  "default": "#667eea" },
		"cardBorderRadius":  { "type": "number",  "default": 8 },
		"padding": {
			"type": "object",
			"default": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
		},
		"paddingTablet":     { "type": "object",  "default": null },
		"paddingMobile":     { "type": "object",  "default": null },
		"paddingUnit":       { "type": "string",  "default": "px" },
		"margin": {
			"type": "object",
			"default": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
		},
		"marginTablet":      { "type": "object",  "default": null },
		"marginMobile":      { "type": "object",  "default": null },
		"marginUnit":        { "type": "string",  "default": "px" },
		"boxShadow":         { "type": "boolean", "default": false },
		"shadowHorizontal":  { "type": "number",  "default": 0 },
		"shadowVertical":    { "type": "number",  "default": 8 },
		"shadowBlur":        { "type": "number",  "default": 24 },
		"shadowSpread":      { "type": "number",  "default": 0 },
		"shadowColor":       { "type": "string",  "default": "rgba(0, 0, 0, 0.08)" },
		"borderRadius": {
			"type": "object",
			"default": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
		},
		"borderRadiusUnit":  { "type": "string",  "default": "px" },
		"hideOnDesktop":     { "type": "boolean", "default": false },
		"hideOnTablet":      { "type": "boolean", "default": false },
		"hideOnMobile":      { "type": "boolean", "default": false }
	},
	"supports": {
		"html": false,
		"align": ["wide", "full"],
		"color": {
			"background": true,
			"text": false
		},
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle":  "file:./index.css",
	"style":        "file:./style-index.css",
	"viewScript":   "file:./view.js",
	"render":       "file:./render.php"
}
