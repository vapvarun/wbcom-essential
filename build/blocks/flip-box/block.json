{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wbcom-essential/flip-box",
  "version": "1.0.0",
  "title": "Flip Box",
  "category": "essential-design",
  "icon": "layout",
  "description": "3D card that flips on hover to reveal a back face with title, description, and button.",
  "keywords": [
    "flip",
    "card",
    "hover",
    "3d",
    "box",
    "front",
    "back",
    "essential",
    "wbcom"
  ],
  "textdomain": "wbcom-essential",
  "example": {
    "attributes": {
      "frontTitle": "Front Title",
      "frontDescription": "Hover to see the back",
      "flipDirection": "horizontal"
    }
  },
  "attributes": {
    "uniqueId": {
      "type": "string",
      "default": ""
    },
    "frontTitle": {
      "type": "string",
      "default": "Front Title"
    },
    "frontDescription": {
      "type": "string",
      "default": "Hover to see the back"
    },
    "frontIcon": {
      "type": "string",
      "default": "⚡"
    },
    "frontBg": {
      "type": "string",
      "default": "#667eea"
    },
    "frontColor": {
      "type": "string",
      "default": "#ffffff"
    },
    "backTitle": {
      "type": "string",
      "default": "Back Title"
    },
    "backDescription": {
      "type": "string",
      "default": "This is the back of the card"
    },
    "backButtonText": {
      "type": "string",
      "default": "Learn More"
    },
    "backButtonUrl": {
      "type": "string",
      "default": "#"
    },
    "backBg": {
      "type": "string",
      "default": "#764ba2"
    },
    "backColor": {
      "type": "string",
      "default": "#ffffff"
    },
    "flipDirection": {
      "type": "string",
      "default": "horizontal"
    },
    "height": {
      "type": "number",
      "default": 300
    },
    "heightUnit": {
      "type": "string",
      "default": "px"
    },
    "padding": {
      "type": "object",
      "default": {
        "top": 0,
        "right": 0,
        "bottom": 0,
        "left": 0
      }
    },
    "paddingTablet": {
      "type": "object",
      "default": null
    },
    "paddingMobile": {
      "type": "object",
      "default": null
    },
    "paddingUnit": {
      "type": "string",
      "default": "px"
    },
    "margin": {
      "type": "object",
      "default": {
        "top": 0,
        "right": 0,
        "bottom": 0,
        "left": 0
      }
    },
    "marginTablet": {
      "type": "object",
      "default": null
    },
    "marginMobile": {
      "type": "object",
      "default": null
    },
    "marginUnit": {
      "type": "string",
      "default": "px"
    },
    "boxShadow": {
      "type": "boolean",
      "default": false
    },
    "shadowHorizontal": {
      "type": "number",
      "default": 0
    },
    "shadowVertical": {
      "type": "number",
      "default": 8
    },
    "shadowBlur": {
      "type": "number",
      "default": 24
    },
    "shadowSpread": {
      "type": "number",
      "default": 0
    },
    "shadowColor": {
      "type": "string",
      "default": "rgba(0, 0, 0, 0.15)"
    },
    "borderRadius": {
      "type": "object",
      "default": {
        "top": 12,
        "right": 12,
        "bottom": 12,
        "left": 12
      }
    },
    "borderRadiusUnit": {
      "type": "string",
      "default": "px"
    },
    "hideOnDesktop": {
      "type": "boolean",
      "default": false
    },
    "hideOnTablet": {
      "type": "boolean",
      "default": false
    },
    "hideOnMobile": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "color": {
      "background": false,
      "text": false
    },
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js"
}