{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wbcom-essential/login-form",
  "version": "1.0.0",
  "title": "Login Form",
  "category": "essential-content",
  "icon": "admin-users",
  "description": "WordPress login form with customisable colours, redirect URL, and optional register/lost-password links.",
  "keywords": [
    "login",
    "form",
    "sign in",
    "authentication",
    "user",
    "account",
    "essential",
    "wbcom"
  ],
  "textdomain": "wbcom-essential",
  "example": {
    "attributes": {
      "buttonText": "Log In",
      "showRememberMe": true,
      "showRegisterLink": true,
      "showLostPassword": true
    }
  },
  "attributes": {
    "uniqueId": {
      "type": "string",
      "default": ""
    },
    "redirectUrl": {
      "type": "string",
      "default": ""
    },
    "showRememberMe": {
      "type": "boolean",
      "default": true
    },
    "showRegisterLink": {
      "type": "boolean",
      "default": true
    },
    "showLostPassword": {
      "type": "boolean",
      "default": true
    },
    "buttonText": {
      "type": "string",
      "default": "Log In"
    },
    "loggedInMessage": {
      "type": "string",
      "default": "You are already logged in."
    },
    "formBg": {
      "type": "string",
      "default": "#ffffff"
    },
    "buttonBg": {
      "type": "string",
      "default": "#667eea"
    },
    "buttonColor": {
      "type": "string",
      "default": "#ffffff"
    },
    "labelColor": {
      "type": "string",
      "default": "#1e1e2e"
    },
    "linkColor": {
      "type": "string",
      "default": "#667eea"
    },
    "padding": {
      "type": "object",
      "default": {
        "top": 40,
        "right": 40,
        "bottom": 40,
        "left": 40
      }
    },
    "paddingTablet": {
      "type": "object",
      "default": null
    },
    "paddingMobile": {
      "type": "object",
      "default": null
    },
    "paddingUnit": {
      "type": "string",
      "default": "px"
    },
    "margin": {
      "type": "object",
      "default": {
        "top": 0,
        "right": 0,
        "bottom": 0,
        "left": 0
      }
    },
    "marginTablet": {
      "type": "object",
      "default": null
    },
    "marginMobile": {
      "type": "object",
      "default": null
    },
    "marginUnit": {
      "type": "string",
      "default": "px"
    },
    "boxShadow": {
      "type": "boolean",
      "default": false
    },
    "shadowHorizontal": {
      "type": "number",
      "default": 0
    },
    "shadowVertical": {
      "type": "number",
      "default": 4
    },
    "shadowBlur": {
      "type": "number",
      "default": 8
    },
    "shadowSpread": {
      "type": "number",
      "default": 0
    },
    "shadowColor": {
      "type": "string",
      "default": "rgba(0, 0, 0, 0.12)"
    },
    "borderRadius": {
      "type": "object",
      "default": {
        "top": 12,
        "right": 12,
        "bottom": 12,
        "left": 12
      }
    },
    "borderRadiusUnit": {
      "type": "string",
      "default": "px"
    },
    "hideOnDesktop": {
      "type": "boolean",
      "default": false
    },
    "hideOnTablet": {
      "type": "boolean",
      "default": false
    },
    "hideOnMobile": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "color": {
      "background": true,
      "text": true
    },
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "render": "file:./render.php",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}