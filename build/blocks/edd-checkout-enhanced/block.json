{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wbcom-essential/edd-checkout-enhanced",
  "version": "2.0.0",
  "title": "EDD Enhanced Checkout",
  "category": "essential-design",
  "icon": "cart",
  "description": "Enhanced checkout page with progress bar, trust badges, reviews, and recommendations wrapping EDD's native checkout.",
  "keywords": [
    "edd",
    "checkout",
    "payment",
    "cart",
    "easy digital downloads"
  ],
  "textdomain": "wbcom-essential",
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "attributes": {
    "showProgressBar": {
      "type": "boolean",
      "default": true
    },
    "showTrustBadges": {
      "type": "boolean",
      "default": true
    },
    "trustBadgeText": {
      "type": "string",
      "default": "Secure checkout powered by Stripe"
    },
    "showReviews": {
      "type": "boolean",
      "default": true
    },
    "reviewCount": {
      "type": "number",
      "default": 3
    },
    "showRecommendations": {
      "type": "boolean",
      "default": true
    },
    "recommendationCount": {
      "type": "number",
      "default": 3
    },
    "showTrustpilot": {
      "type": "boolean",
      "default": true
    },
    "trustpilotRating": {
      "type": "number",
      "default": 4.7
    },
    "trustpilotCount": {
      "type": "number",
      "default": 87
    },
    "trustpilotUrl": {
      "type": "string",
      "default": ""
    },
    "trustpilotReviews": {
      "type": "array",
      "default": [
        {
          "name": "S W Malcolm",
          "stars": 5,
          "title": "Excellent Theme, Powerful Plugins and Outstanding Support",
          "text": "Outstanding customer support: quick, helpful, and always willing to go the extra mile."
        },
        {
          "name": "Steve",
          "stars": 5,
          "title": "Great speedy support and great plugins",
          "text": "Great speedy support and great plugins. Highly recommended for BuddyPress communities."
        },
        {
          "name": "Real America's Voice News",
          "stars": 5,
          "title": "THE BEST DEVELOPMENT TEAM EVER!",
          "text": "Very professional and productive, completing tasks in a quick and decisive manner."
        }
      ]
    },
    "paymentIcons": {
      "type": "object",
      "default": {
        "visa": true,
        "mastercard": true,
        "paypal": true,
        "stripe": true,
        "razorpay": true
      }
    },
    "uniqueId": {
      "type": "string",
      "default": ""
    },
    "padding": {
      "type": "object",
      "default": {
        "top": 24,
        "right": 24,
        "bottom": 24,
        "left": 24
      }
    },
    "paddingTablet": {
      "type": "object",
      "default": null
    },
    "paddingMobile": {
      "type": "object",
      "default": null
    },
    "paddingUnit": {
      "type": "string",
      "default": "px"
    },
    "margin": {
      "type": "object",
      "default": {
        "top": 0,
        "right": 0,
        "bottom": 0,
        "left": 0
      }
    },
    "marginTablet": {
      "type": "object",
      "default": null
    },
    "marginMobile": {
      "type": "object",
      "default": null
    },
    "marginUnit": {
      "type": "string",
      "default": "px"
    },
    "boxShadow": {
      "type": "boolean",
      "default": false
    },
    "shadowHorizontal": {
      "type": "number",
      "default": 0
    },
    "shadowVertical": {
      "type": "number",
      "default": 4
    },
    "shadowBlur": {
      "type": "number",
      "default": 8
    },
    "shadowSpread": {
      "type": "number",
      "default": 0
    },
    "shadowColor": {
      "type": "string",
      "default": "rgba(0, 0, 0, 0.12)"
    },
    "borderRadius": {
      "type": "object",
      "default": {
        "top": 0,
        "right": 0,
        "bottom": 0,
        "left": 0
      }
    },
    "borderRadiusUnit": {
      "type": "string",
      "default": "px"
    },
    "hideOnDesktop": {
      "type": "boolean",
      "default": false
    },
    "hideOnTablet": {
      "type": "boolean",
      "default": false
    },
    "hideOnMobile": {
      "type": "boolean",
      "default": false
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}