{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wbcom-essential/group-carousel",
  "version": "1.0.0",
  "title": "Group Carousel",
  "category": "essential-buddypress",
  "icon": "slides",
  "description": "Display BuddyPress groups in an interactive Swiper carousel with configurable slides, autoplay, and card styles.",
  "keywords": [
    "groups",
    "carousel",
    "slider",
    "buddypress",
    "community",
    "swiper",
    "essential",
    "wbcom"
  ],
  "textdomain": "wbcom-essential",
  "example": {},
  "attributes": {
    "uniqueId": {
      "type": "string",
      "default": ""
    },
    "totalGroups": {
      "type": "number",
      "default": 12
    },
    "sortType": {
      "type": "string",
      "default": "active"
    },
    "slidesPerView": {
      "type": "number",
      "default": 3
    },
    "slidesPerViewTablet": {
      "type": "number",
      "default": 2
    },
    "slidesPerViewMobile": {
      "type": "number",
      "default": 1
    },
    "autoplay": {
      "type": "boolean",
      "default": true
    },
    "autoplayDelay": {
      "type": "number",
      "default": 3000
    },
    "loop": {
      "type": "boolean",
      "default": true
    },
    "showDots": {
      "type": "boolean",
      "default": true
    },
    "showArrows": {
      "type": "boolean",
      "default": true
    },
    "showDescription": {
      "type": "boolean",
      "default": false
    },
    "showMemberCount": {
      "type": "boolean",
      "default": true
    },
    "spaceBetween": {
      "type": "number",
      "default": 24
    },
    "cardBg": {
      "type": "string",
      "default": "#ffffff"
    },
    "nameColor": {
      "type": "string",
      "default": "#1e1e2e"
    },
    "avatarSize": {
      "type": "number",
      "default": 80
    },
    "padding": {
      "type": "object",
      "default": {
        "top": 0,
        "right": 0,
        "bottom": 0,
        "left": 0
      }
    },
    "paddingTablet": {
      "type": "object",
      "default": null
    },
    "paddingMobile": {
      "type": "object",
      "default": null
    },
    "paddingUnit": {
      "type": "string",
      "default": "px"
    },
    "margin": {
      "type": "object",
      "default": {
        "top": 0,
        "right": 0,
        "bottom": 0,
        "left": 0
      }
    },
    "marginTablet": {
      "type": "object",
      "default": null
    },
    "marginMobile": {
      "type": "object",
      "default": null
    },
    "marginUnit": {
      "type": "string",
      "default": "px"
    },
    "boxShadow": {
      "type": "boolean",
      "default": false
    },
    "shadowHorizontal": {
      "type": "number",
      "default": 0
    },
    "shadowVertical": {
      "type": "number",
      "default": 4
    },
    "shadowBlur": {
      "type": "number",
      "default": 8
    },
    "shadowSpread": {
      "type": "number",
      "default": 0
    },
    "shadowColor": {
      "type": "string",
      "default": "rgba(0, 0, 0, 0.12)"
    },
    "borderRadius": {
      "type": "object",
      "default": {
        "top": 12,
        "right": 12,
        "bottom": 12,
        "left": 12
      }
    },
    "borderRadiusUnit": {
      "type": "string",
      "default": "px"
    },
    "showJoinButton": {
      "type": "boolean",
      "default": true
    },
    "hideOnDesktop": {
      "type": "boolean",
      "default": false
    },
    "hideOnTablet": {
      "type": "boolean",
      "default": false
    },
    "hideOnMobile": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "color": false,
    "spacing": false
  },
  "render": "file:./render.php",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": [
    "file:./view.js",
    "swiper"
  ]
}