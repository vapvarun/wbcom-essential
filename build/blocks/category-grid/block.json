{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wbcom-essential/category-grid",
  "version": "2.0.0",
  "title": "Category Grid",
  "category": "essential-blog",
  "icon": "category",
  "description": "Display WordPress categories in a customizable grid layout with images, post counts, and hover effects.",
  "keywords": [
    "categories",
    "grid",
    "taxonomy",
    "blog",
    "magazine",
    "essential",
    "wbcom"
  ],
  "textdomain": "wbcom-essential",
  "example": {},
  "attributes": {
    "useThemeColors": {
      "type": "boolean",
      "default": false
    },
    "columns": {
      "type": "number",
      "default": 4
    },
    "columnsTablet": {
      "type": "number",
      "default": 2
    },
    "columnsMobile": {
      "type": "number",
      "default": 1
    },
    "selectedCategories": {
      "type": "array",
      "default": []
    },
    "excludeEmpty": {
      "type": "boolean",
      "default": true
    },
    "maxCategories": {
      "type": "number",
      "default": 8
    },
    "showPostCount": {
      "type": "boolean",
      "default": true
    },
    "showImage": {
      "type": "boolean",
      "default": true
    },
    "imageRatio": {
      "type": "string",
      "default": "0.75"
    },
    "gap": {
      "type": "number",
      "default": 24
    },
    "cardBorderRadius": {
      "type": "number",
      "default": 12
    },
    "cardBgColor": {
      "type": "string",
      "default": ""
    },
    "nameColor": {
      "type": "string",
      "default": ""
    },
    "countColor": {
      "type": "string",
      "default": ""
    },
    "overlayColor": {
      "type": "string",
      "default": ""
    },
    "orderBy": {
      "type": "string",
      "default": "name"
    },
    "order": {
      "type": "string",
      "default": "ASC"
    },
    "uniqueId": {
      "type": "string",
      "default": ""
    },
    "padding": {
      "type": "object",
      "default": {
        "top": 24,
        "right": 24,
        "bottom": 24,
        "left": 24
      }
    },
    "paddingTablet": {
      "type": "object",
      "default": null
    },
    "paddingMobile": {
      "type": "object",
      "default": null
    },
    "paddingUnit": {
      "type": "string",
      "default": "px"
    },
    "margin": {
      "type": "object",
      "default": {
        "top": 0,
        "right": 0,
        "bottom": 0,
        "left": 0
      }
    },
    "marginTablet": {
      "type": "object",
      "default": null
    },
    "marginMobile": {
      "type": "object",
      "default": null
    },
    "marginUnit": {
      "type": "string",
      "default": "px"
    },
    "boxShadow": {
      "type": "boolean",
      "default": false
    },
    "shadowHorizontal": {
      "type": "number",
      "default": 0
    },
    "shadowVertical": {
      "type": "number",
      "default": 4
    },
    "shadowBlur": {
      "type": "number",
      "default": 8
    },
    "shadowSpread": {
      "type": "number",
      "default": 0
    },
    "shadowColor": {
      "type": "string",
      "default": "rgba(0, 0, 0, 0.12)"
    },
    "borderRadius": {
      "type": "object",
      "default": {
        "top": 0,
        "right": 0,
        "bottom": 0,
        "left": 0
      }
    },
    "borderRadiusUnit": {
      "type": "string",
      "default": "px"
    },
    "hideOnDesktop": {
      "type": "boolean",
      "default": false
    },
    "hideOnTablet": {
      "type": "boolean",
      "default": false
    },
    "hideOnMobile": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}